{
  "Comment": "Order Processing Workflow",
  "StartAt": "ParallelProcessing",
  "States": {
    "ParallelProcessing": {
      "Type": "Parallel",
      "Next": "PublishToEventBridge",
      "Branches": [
        {
          "StartAt": "ProcessPayment",
          "States": {
            "ProcessPayment": {
              "Type": "Task",
              "Resource": "${PaymentFunctionArn}",
              "End": true
            }
          }
        },
        {
          "StartAt": "ProcessInventory",
          "States": {
            "ProcessInventory": {
              "Type": "Task",
              "Resource": "${InventoryFunctionArn}",
              "End": true
            }
          }
        }
      ]
    },
    "PublishToEventBridge": {
      "Type": "Task",
      "Resource": "arn:aws:states:::events:putEvents",
      "Parameters": {
        "Entries": [
          {
            "Detail.$": "States.JsonToString($)",
            "DetailType": "OrderProcessed",
            "EventBusName": "${EventBusName}",
            "Source": "checkout.workflow"
          }
        ]
      },
      "End": true
    }
  }
}