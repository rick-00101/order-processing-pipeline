{
  "Comment": "Multi-branch checkout processing workflow",
  "StartAt": "ProcessCheckoutParallel",
  "States": {
    "ProcessCheckoutParallel": {
      "Type": "Parallel",
      "Next": "PublishToEventBridge",
      "Branches": [
        {
          "StartAt": "AuthorizePayment",
          "States": {
            "AuthorizePayment": {
              "Type": "Task",
              "Resource": "${PaymentFunctionArn}",
              "End": true
            }
          }
        },
        {
          "StartAt": "VerifyInventory",
          "States": {
            "VerifyInventory": {
              "Type": "Task",
              "Resource": "${InventoryFunctionArn}",
              "End": true
            }
          }
        }
      ]
    },
    "PublishToEventBridge": {
      "Type": "Task",
      "Resource": "arn:aws:states:::events:putEvents",
      "Parameters": {
        "Entries": [
          {
            "Detail.$": "States.JsonToString($)", 
            "DetailType": "OrderProcessed",
            "EventBusName": "${EventBusName}",
            "Source": "checkout.workflow"
          }
        ]
      },
      "End": true
    }
  }
}
